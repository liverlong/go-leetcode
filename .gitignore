# ==========================================
# macOS 系统文件 (必加，防止污染代码库)
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ==========================================
# Golang 编译与测试输出
# ==========================================
# 编译后的二进制可执行文件 (根据你的系统和编译目标)
*.exe
*.exe~
*.dll
*.so
*.dylib

# 常用存放编译后二进制文件的目录
bin/
build/

# 测试生成的二进制文件 (go test -c)
*.test

# 测试覆盖率报告
*.out
coverage.txt
coverage.html

# 本地多模块开发工作区文件 (不应提交到远端)
go.work
go.work.sum

# 依赖包目录 (目前 Go Modules 时代通常不需要提交 vendor 目录)
# 如果你需要离线编译并决定保留 vendor，请注释掉下面这行
vendor/

# ==========================================
# IDE 与编辑器配置文件
# ==========================================
# GoLand (JetBrains)
.idea/
*.iml

# VS Code
.vscode/

# Vim / Emacs 临时文件
*.swp
*.swo
*~
